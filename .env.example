# AI API Keys for ChatGPT, Claude, and Gemini Integration
# Get your API keys from the respective platforms and add them here

# OpenAI ChatGPT API
# Get from: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=sk_test_your_openai_api_key_here

# Anthropic Claude API
# Get from: https://console.anthropic.com/
NEXT_PUBLIC_CLAUDE_API_KEY=sk-ant_your_claude_api_key_here

# Google Gemini API
# Get from: https://makersuite.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# Optional: Custom exchange rate for INR conversion (default: 83.5)
# NEXT_PUBLIC_INR_EXCHANGE_RATE=83.5

# Optional: Timezone for timestamp displays
# NEXT_PUBLIC_TIMEZONE=Asia/Kolkata
